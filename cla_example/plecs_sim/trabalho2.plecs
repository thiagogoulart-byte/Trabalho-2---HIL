          }
          Parameter {
            Variable      "Declarations"
            Value         "#define max InputSignal(0,0)\n"
"#define PU InputSignal(0,1)\n"
"\n"
"static int cont;\n"
"static int out;\n"
"float delay = 0.1;\n"
"double queda;\n"
"int salv = 1;"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "out = 0;\n"
"queda = 10.0;"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "OutputSignal(0,0) = out;\n"
"OutputSignal(0,1) = queda;\n"
"OutputSignal(0,2) = PU;\n"
"\n"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         "if (PU != 1 && salv == 1)\n"
"{\n"
"\tqueda = CurrentTime + delay;\n"
"\tsalv = 0;\n"
"}\n"
"\n"
"if (CurrentTime > queda)\n"
"{\n"
"\tout = 0;\n"
"}\n"
"\n"
"if (max == 1)\n"
"{\n"
"\tcont += 1;\n"
"}\n"
"\n"
"if (cont > 2 && salv == 1)\n"
"{\n"
"\tout = 1;\n"
"}\n"
"\n"
            Show          off
          }
