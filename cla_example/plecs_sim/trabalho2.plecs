"7CmRvdWJsZSBpTDA7CmRvdWJsZSB2aW52Owpkb3VibGUgVmRjID0gNDAwOwpkb3VibGUgZm4gPSA2"
"MDsKZG91YmxlIGZzID0gMjAwMDA7CmRvdWJsZSBMID0gM2UtMzsKZG91YmxlIFhSID0gMzA7IApkb"
"3VibGUgVHM7CmRvdWJsZSBSOwpkb3VibGUgVG47Cgpkb3VibGUgdTA7CmRvdWJsZSB1MTsKZG91Ym"
"xlIGExOwpkb3VibGUgYjE7CmRvdWJsZSBiMDsKCmRvdWJsZSBrMTsKZG91YmxlIGsyOw=="
        Show          off
      }
      Parameter {
        Variable      "StartFcn"
        Value         "iL = 0.0;\n"
"iL0 = 0.0;\n"
"Ts = 1/FCLK;\n"
"Tn = 1/fs;\n"
"//R = 2*PI*fn*L/XR;\n"
"R = 0.018849555;\n"
"\n"
"\n"
"a1 = ((2*L/Ts) - R) / ((2*L/Ts) + R);\n"
"\n"
"b0 = 1.0 / ((2*L/Ts) + R);\n"
"\n"
"b1 = b0;\n"
"\n"
"\n"
"/* tava usando esse\n"
"a1 = ((2*L/Ts) - R) / ((2*L/Ts) + R);\n"
"b0 = 1.0 / (2*((2*L/Ts) + R));\n"
"\n"
"b1 = b0;\n"
"*/\n"
"\n"
"/*\n"
"a1 = (2 * L)/(2 * L - Ts*R);\n"
"b0 = (2 * L + Ts*R)/(2 * L);\n"
"b1 = -(Ts/(4*L));\n"
"*/\n"
"u0=0.0;\n"
"u1=0.0;\n"
"\n"
"k1 = (2.0*L - 2.0*R*Ts)/(2.0*L + 2.0*R*Ts);\n"
"k2 = Ts/(2.0*L + 2.0*R*Ts);"
        Show          off
      }
      Parameter {
        Variable      "OutputFcn"
        Value         "if(S1 == 1 && S4 == 1)\n"
"    vinv = Vdc;\n"
"\n"
"else if(S2 == 1 && S3 == 1)\n"
"    vinv = -Vdc;\n"
"\n"
"else\n"
"    vinv = 0.0;\n"
"    \n"
"    \n"
"//iL =(iL + (Ts/L)*(vinv - vg))/(1 + (R*Ts/L));\n"
"//iL = iL0 + ((vinv - vg - 2*R*iL0)*Ts)/(2*L);\n"
"\n"
"u0 = vinv - vg;\n"
"\n"
"iL = a1*iL0 + b0*u0 + b1*u1;\n"
"\n"
"\n"
"//iL = k1*iL0 + k2*(u0 + u1);\n"
"\n"
"Output(0) = iL;\n"
"//Output(1) = vg;\n"
        Show          off
      }
      Parameter {
        Variable      "UpdateFcn"
        Value         "u1 = u0;\n"
"iL0 = iL;"
        Show          off
      }
